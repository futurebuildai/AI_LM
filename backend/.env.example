# AI_LM backend configuration. Copy to .env for local development.

# HTTP port (8090 avoids clashing with GableLBM :8080 and Vite :5173).
PORT=8090

# Postgres on the docker-compose mapping (:5434), AI_LM-native database.
DATABASE_URL=postgres://gable_user:gable_password@localhost:5434/ai_lm_db?sslmode=disable

# Auth: "dev" disables JWT for local development. In production leave AUTH_MODE
# unset and provide JWKS_URL (fail-closed). Share the GableLBM JWKS.
AUTH_MODE=dev
JWKS_URL=
AUTH_ISSUER=

# GableLBM integration — source of truth for orders/products/vehicles.
GABLE_API_URL=http://localhost:8080
GABLE_INTEGRATION_KEY=

# Logging: DEBUG, INFO, WARN, ERROR.
LOG_LEVEL=INFO

# Connection pool sizing.
DB_MAX_CONNS=25
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME_MIN=60

# CORS (required when AUTH_MODE != dev). Comma-separated origins.
# CORS_ORIGINS=https://ai-lm.example.com
