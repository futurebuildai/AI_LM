# AI_LM backend configuration. Copy to .env for local development.

# HTTP port (8090 avoids clashing with GableLBM :8080 and Vite :5173).
PORT=8090

# Postgres on the docker-compose mapping (:5434), AI_LM-native database.
DATABASE_URL=postgres://gable_user:gable_password@localhost:5434/ai_lm_db?sslmode=disable

# Auth: "dev" disables JWT for local development. In production leave AUTH_MODE
# unset and provide SESSION_SECRET (fail-closed) — AI_LM mints its own staff
# session tokens via POST /api/v1/auth/login. JWKS_URL is optional and only
# needed to additionally accept externally-issued (shared GableLBM JWKS) tokens.
AUTH_MODE=dev
# SESSION_SECRET signs/verifies AI_LM staff session JWTs. REQUIRED when
# AUTH_MODE != dev. Use a long random value (e.g. `openssl rand -hex 32`).
SESSION_SECRET=
JWKS_URL=
AUTH_ISSUER=

# GableLBM integration — source of truth for orders/products/vehicles.
GABLE_API_URL=http://localhost:8080
GABLE_INTEGRATION_KEY=

# --- Pillar 6: OSS inference (all optional — the app runs with none set) ------
#
# OpenRouteService — real OSS routing (road distance/duration matrix). When
# ORS_API_KEY is set the route optimizer uses ORS (driving-hgv by default);
# when unset it falls back to the built-in haversine heuristic (no hard-fail).
ORS_API_KEY=
ORS_BASE_URL=https://api.openrouteservice.org
ORS_PROFILE=driving-hgv
#
# OpenRouter — single-key, OpenAI-compatible LLM client (open-weight default
# model) used for the AI dispatch briefing. When OPENROUTER_API_KEY is unset the
# briefing endpoint reports "unavailable" and the workflow is never blocked.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# Logging: DEBUG, INFO, WARN, ERROR.
LOG_LEVEL=INFO

# Connection pool sizing.
DB_MAX_CONNS=25
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME_MIN=60

# CORS (required when AUTH_MODE != dev). Comma-separated origins.
# CORS_ORIGINS=https://ai-lm.example.com
